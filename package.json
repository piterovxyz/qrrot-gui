{
  "name": "qrrot-gui",
  "author": {
    "email": "me@piterov.xyz",
    "name": "Artur Piterov",
    "url": "https://piterov.xyz"
  },
  "version": "1.3.3",
  "description": "gRPC desktop client for qrrot database",
  "main": "main.js",
  "type": "commonjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:start": "electron .",
    "test": "vitest run",
    "dist": "vite build && electron-builder"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.10.9",
    "@grpc/proto-loader": "^0.8.1",
    "framer-motion": "^12.40.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.9",
    "autoprefixer": "^10.5.0",
    "clsx": "^2.1.1",
    "electron": "42.4.1",
    "electron-builder": "^24.13.3",
    "jest": "^30.4.2",
    "jsdom": "^29.1.1",
    "lucide-react": "^1.21.0",
    "postcss": "^8.5.15",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^3.4.19",
    "vite": "8.0.16",
    "vitest": "^4.1.9"
  },
  "build": {
    "appId": "com.qrrot.gui",
    "productName": "Qrrot",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "main.js",
      "preload.js",
      "package.json",
      "proto/**/*"
    ],
    "asarUnpack": [
      "proto/**"
    ],
    "mac": {
      "target": ["dmg"]
    },
    "win": {
      "target": ["nsis"]
    },
    "linux": {
      "target": ["AppImage"]
    }
  },
  "overrides": {
    "yauzl": "^3.3.1"
  },
  "allowScripts": {
    "protobufjs@7.6.4": true,
    "unrs-resolver@1.12.2": true
  }
}
